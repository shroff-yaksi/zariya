{%- comment -%} Zariya House — Corporate Gifting page {%- endcomment -%}
{%- assign sig = section.settings.intro_image_asset | default: 'hero.png' | asset_url -%}
<div class="zariya">
  <section class="zh-banner parchment">
    <div class="zh-banner__eyebrow">{{ section.settings.eyebrow | default: 'For Businesses' }}</div>
    <h1>{{ section.settings.heading | default: 'Corporate Gifting' }}</h1>
    <p>{{ section.settings.subheading | default: 'A Signature Corporate gesture that builds a lifelong partnership — thoughtfully crafted, impeccably delivered.' }}</p>
    <div class="zh-divider" style="--w:90px"><span class="line"></span><span style="font-size:13px">❖</span><span class="line"></span></div>
  </section>

  <section class="parchment" style="padding:0 48px">
    <div class="wrap"><div class="story-row">
      <div class="story-row__media"><img src="{% if section.settings.intro_image != blank %}{{ section.settings.intro_image | image_url: width: 900 }}{% else %}{{ sig }}{% endif %}" alt="Corporate gifting hamper" width="900" height="600" loading="lazy"></div>
      <div>
        <div class="story-eyebrow">Gifting, Elevated</div>
        <h2>Gestures that command a place in the boardroom — and the heart.</h2>
        <p>At Zariya House, corporate gifting is never mass-produced. We work directly with master artisans so every chest that carries your name reflects the discipline of a professional and the soul of an artist.</p>
        <p>Whether you are thanking clients, rewarding teams or celebrating a milestone, we manage the heritage of your most important relationships — from sourcing to the final ribbon.</p>
        <a href="{{ section.settings.cta_link | default: '/pages/contact' }}" class="btn btn-green" style="margin-top:8px">Request a Quote →</a>
      </div>
    </div></div>
  </section>

  <section class="parchment gold-rule" style="padding:52px 48px">
    <div class="zh-divider" style="margin-bottom:38px"><span class="line"></span><span style="font-size:13px">❖</span>
      <h2 style="font-family:var(--f-display);font-weight:600;font-size:32px;color:var(--maroon)">Why Brands Choose Zariya</h2>
      <span style="font-size:13px">❖</span><span class="line"></span></div>
    <div class="features wrap">
      <div class="feature"><div class="feature__ic">{% render 'zariya-icons', name: 'box' %}</div><h4>Bulk Ordering</h4><p>Seamless large-volume orders with consistent quality across every box.</p></div>
      <div class="feature"><div class="feature__ic">{% render 'zariya-icons', name: 'brush' %}</div><h4>Custom Branding</h4><p>Your logo, colours and a personal note woven into each hamper.</p></div>
      <div class="feature"><div class="feature__ic">{% render 'zariya-icons', name: 'truck' %}</div><h4>Pan-India Delivery</h4><p>Coordinated dispatch to every recipient, on your timeline.</p></div>
      <div class="feature"><div class="feature__ic">{% render 'zariya-icons', name: 'user' %}</div><h4>Dedicated Manager</h4><p>A single point of contact to manage your entire gifting programme.</p></div>
    </div>
  </section>

  <section class="parchment gold-rule" style="padding:52px 48px 60px;text-align:center">
    <div class="zh-divider" style="margin-bottom:22px"><span class="line"></span><span style="font-size:13px">❖</span>
      <h2 style="font-family:var(--f-display);font-weight:600;font-size:32px;color:var(--maroon)">Fully Customisable Hampers</h2>
      <span style="font-size:13px">❖</span><span class="line"></span></div>
    <p style="max-width:780px;margin:0 auto;font-size:18px;line-height:1.75;color:var(--muted)">{{ section.settings.custom_text | default: 'Every corporate hamper is curated around your brand, occasion and budget — from the contents and colour palette to custom branding, a personal note and the finishing ribbon. There is no fixed catalogue; tell us your vision and quantity, and our team will craft a bespoke proposal, end to end.' }}</p>
  </section>

  <section id="zariya-cta" class="cta-band">
    <h2>{{ section.settings.cta_heading | default: "Let's craft your corporate gifting programme" }}</h2>
    <p>{{ section.settings.cta_text | default: 'Tell us your occasion, quantity and timeline. Our team will design a bespoke proposal within 48 hours.' }}</p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="{{ section.settings.cta_link | default: '/pages/contact' }}" class="btn btn-gold">{{ section.settings.cta_btn | default: 'Contact Us to Enquire' }}</a>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Zariya Corporate",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "For Businesses" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Corporate Gifting" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "A Signature Corporate gesture that builds a lifelong partnership — thoughtfully crafted, impeccably delivered." },
    { "type": "image_picker", "id": "intro_image", "label": "Intro image" },
    { "type": "text", "id": "intro_image_asset", "label": "Intro image asset filename (used if none picked)", "default": "heritage-chest-1.jpg" },
    { "type": "textarea", "id": "custom_text", "label": "Customisation text", "default": "Every corporate hamper is curated around your brand, occasion and budget — from the contents and colour palette to custom branding, a personal note and the finishing ribbon. There is no fixed catalogue; tell us your vision and quantity, and our team will craft a bespoke proposal, end to end." },
    { "type": "text", "id": "cta_heading", "label": "CTA heading", "default": "Let's craft your corporate gifting programme" },
    { "type": "textarea", "id": "cta_text", "label": "CTA text", "default": "Tell us your occasion, quantity and timeline. Our team will design a bespoke proposal within 48 hours." },
    { "type": "url", "id": "cta_link", "label": "Contact / Request a Quote link" },
    { "type": "text", "id": "cta_btn", "label": "CTA button label", "default": "Contact Us to Enquire" }
  ],
  "presets": [{ "name": "Zariya Corporate" }]
}
{% endschema %}
