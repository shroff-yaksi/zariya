{%- comment -%} Zariya House — Shop (banner + filter pills + product cards) {%- endcomment -%}
<div class="zariya">
  <section class="zh-banner parchment">
    <div class="zh-banner__eyebrow">{{ section.settings.eyebrow }}</div>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <div class="zh-divider" style="--w:90px"><span class="line"></span><span style="font-size:13px">❖</span><span class="line"></span></div>
  </section>

  <section class="parchment" style="padding:36px 48px 60px">
    {%- if section.settings.show_filters -%}
      <div class="wrap" style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-bottom:38px">
        {%- assign cats = section.settings.filters | split: ',' -%}
        {%- for c in cats -%}
          <a href="#" style="font-family:var(--f-display);font-size:17px;color:{% if forloop.first %}var(--green){% else %}var(--gold-muted){% endif %};text-decoration:none;padding:8px 20px;border:1px solid var(--gold-border);border-radius:30px;background:{% if forloop.first %}rgba(44,56,49,.06){% else %}transparent{% endif %}">{{ c | strip }}</a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="grid-4 wrap">
      {%- for block in section.blocks -%}
        {%- assign soon = block.settings.coming_soon -%}
        {%- assign card_link = block.settings.link | default: '/collections/all' -%}
        {%- capture card_img -%}
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 520 }}" alt="{{ block.settings.name | escape }}" width="540" height="380" loading="lazy">
          {%- else -%}
            <img src="{{ block.settings.fallback | default: 'card-festive.png' | asset_url }}" alt="{{ block.settings.name | escape }}" width="540" height="380" loading="lazy">
          {%- endif -%}
        {%- endcapture -%}
        <article class="card{% if soon %} card--soon{% endif %}" {{ block.shopify_attributes }}>
          {%- if soon -%}
            <span class="tag tag--soon">Coming Soon</span>
            <div class="card__media">{{ card_img }}</div>
          {%- else -%}
            {%- if block.settings.tag != blank -%}<span class="tag">{{ block.settings.tag }}</span>{%- endif -%}
            <a href="{{ card_link }}" style="text-decoration:none;display:block">{{ card_img }}</a>
          {%- endif -%}
          <div class="card__body">
            <div style="font-family:var(--f-display);letter-spacing:2px;font-size:12px;text-transform:uppercase;color:var(--gold-muted)">{{ block.settings.category }}</div>
            {%- if soon -%}
              <h3 style="margin-top:4px">{{ block.settings.name }}</h3>
            {%- else -%}
              <h3 style="margin-top:4px"><a href="{{ card_link }}" style="color:inherit;text-decoration:none">{{ block.settings.name }}</a></h3>
              <div class="price">{{ block.settings.price }}{% if block.settings.compare != blank %}<span class="cut">{{ block.settings.compare }}</span>{% endif %}</div>
              <a href="{{ card_link }}" class="btn btn-green">View Hamper</a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.more_label != blank -%}
      <div style="text-align:center;margin-top:44px"><a href="{{ section.settings.more_link | default: '#' }}" class="btn btn-maroon">{{ section.settings.more_label }}</a></div>
    {%- endif -%}
  </section>
</div>

{% schema %}
{
  "name": "Zariya Shop",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated Hampers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop All Hampers" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Handcrafted gift hampers for every celebration — each piece a keepsake, made by master artisans." },
    { "type": "checkbox", "id": "show_filters", "label": "Show filter pills", "default": true },
    { "type": "text", "id": "filters", "label": "Filter pills (comma separated)", "default": "All Hampers, Wedding, Festive, Kids, Corporate, Personalised" },
    { "type": "text", "id": "more_label", "label": "Load more button label", "default": "Load More Hampers" },
    { "type": "url", "id": "more_link", "label": "Load more link" }
  ],
  "blocks": [
    { "type": "product", "name": "Product card", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "select", "id": "fallback", "label": "Fallback image", "default": "card-festive.png",
        "options": [
          {"value":"heritage-chest-card.jpg","label":"Heritage Chest"},
          {"value":"card-wedding.png","label":"Wedding"},{"value":"card-festive.png","label":"Festive"},
          {"value":"card-kids.png","label":"Kids"},{"value":"card-corporate.png","label":"Corporate"}
        ] },
      { "type": "text", "id": "category", "label": "Category", "default": "Festive" },
      { "type": "text", "id": "name", "label": "Name", "default": "Festive Glow Hamper" },
      { "type": "text", "id": "price", "label": "Price", "default": "₹ 2,999" },
      { "type": "text", "id": "compare", "label": "Compare-at price (optional)" },
      { "type": "text", "id": "tag", "label": "Tag badge (optional)" },
      { "type": "checkbox", "id": "coming_soon", "label": "Coming soon (dim card, hide price & link)", "default": false },
      { "type": "url", "id": "link", "label": "Link" }
    ]}
  ],
  "presets": [{
    "name": "Zariya Shop",
    "blocks": [
      {"type":"product","settings":{"fallback":"card-wedding.png","category":"Wedding","name":"The Heritage Wedding Chest","price":"₹ 6,499","compare":"₹ 7,999","tag":"Bestseller"}},
      {"type":"product","settings":{"fallback":"card-festive.png","category":"Festive","name":"Festive Glow Hamper","price":"₹ 2,999"}},
      {"type":"product","settings":{"fallback":"card-kids.png","category":"Kids","name":"Little Wonders Box","price":"₹ 1,899"}},
      {"type":"product","settings":{"fallback":"card-corporate.png","category":"Corporate","name":"Corporate Signature Trunk","price":"₹ 5,499","tag":"New"}},
      {"type":"product","settings":{"fallback":"card-festive.png","category":"Festive","name":"Diwali Radiance Hamper","price":"₹ 3,499","compare":"₹ 3,999"}},
      {"type":"product","settings":{"fallback":"card-wedding.png","category":"Wedding","name":"Trousseau Treasure","price":"₹ 8,999"}},
      {"type":"product","settings":{"fallback":"card-corporate.png","category":"Corporate","name":"Executive Gold Box","price":"₹ 4,299"}},
      {"type":"product","settings":{"fallback":"card-kids.png","category":"Kids","name":"Joy & Giggles Hamper","price":"₹ 2,199","tag":"Bestseller"}}
    ]
  }]
}
{% endschema %}
